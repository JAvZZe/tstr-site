---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';

// Static generation
export const prerender = true;

// Fetch published posts
const { data: posts, error } = await supabase
  .from('blog_posts')
  .select('slug, title, excerpt, category, author, published_at, cover_image_url, reading_time_mins')
  .eq('is_published', true)
  .order('published_at', { ascending: false });

const title = "Blog & News | TSTR.directory";
const description = "Latest industry trends, lab spotlights, and regulatory updates in the world of specialist testing and certification.";

// Format date helper
const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
};
---

<BaseLayout title={title} description={description}>
  <main style="max-width: 1200px; margin: 0 auto; padding: 4rem 2rem;">
    <div style="margin-bottom: 4rem; text-align: center;">
      <h1 style="font-size: 3rem; color: #000080; margin-bottom: 1rem;">Blog & News</h1>
      <p style="font-size: 1.2rem; color: #666; max-width: 800px; margin: 0 auto;">
        Stay updated with the latest in laboratory testing, accreditation standards, and industry innovations.
      </p>
    </div>

    {error && (
      <div style="padding: 2rem; background: #fee2e2; border-radius: 8px; color: #dc2626;">
        Error loading posts. Please try again later.
      </div>
    )}

    {!posts || posts.length === 0 ? (
      <div style="text-align: center; padding: 4rem; background: #f9fafb; border-radius: 12px;">
        <p style="font-size: 1.2rem; color: #666;">No articles published yet. Check back soon!</p>
      </div>
    ) : (
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 2.5rem;">
        {posts.map((post) => (
          <article style="background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.08); transition: transform 0.3s ease; display: flex; flex-direction: column;">
            <a href={`/blog/${post.slug}`} style="text-decoration: none; color: inherit; flex-grow: 1;">
              {post.cover_image_url ? (
                <img src={post.cover_image_url} alt={post.title} style="width: 100%; height: 200px; object-fit: cover;" />
              ) : (
                <div style="width: 100%; height: 200px; background: linear-gradient(135deg, #000080 0%, #32CD32 100%); display: flex; align-items: center; justify-content: center; color: white; font-size: 1.5rem; font-weight: bold;">
                  TSTR News
                </div>
              )}
              
              <div style="padding: 1.5rem;">
                <div style="display: flex; gap: 0.75rem; align-items: center; margin-bottom: 1rem;">
                  <span style="background: #e0f2fe; color: #0369a1; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.85rem; font-weight: 600;">
                    {post.category}
                  </span>
                  <span style="color: #6b7280; font-size: 0.85rem;">
                    {post.reading_time_mins} min read
                  </span>
                </div>
                
                <h2 style="font-size: 1.5rem; color: #000080; margin-bottom: 1rem; line-height: 1.2;">{post.title}</h2>
                <p style="color: #4b5563; margin-bottom: 1.5rem; line-height: 1.6;">{post.excerpt}</p>
                
                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 1rem; border-top: 1px solid #f3f4f6;">
                  <span style="color: #9ca3af; font-size: 0.85rem;">{formatDate(post.published_at)}</span>
                  <span style="color: #32CD32; font-weight: 600; display: flex; align-items: center;">
                    Read More 
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 0.25rem;"><path d="m9 18 6-6-6-6"/></svg>
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    )}
  </main>

  <style>
    article:hover {
      transform: translateY(-5px);
    }
  </style>
</BaseLayout>
