---
// export const prerender = true;
import { supabase } from '../../lib/supabase'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Footer from '../../components/Footer.astro'
import StandardMatrix from '../../components/StandardMatrix'
import ContactLabModal from '../../components/ContactLabModal'

// Saudi Energy Category IDs
const CATEGORY_IDS = [
  'ac84835d-8f7b-48ed-b67f-21fa1a574768', // Renewable Energy Testing & Certification
  '811e6df8-bdf9-4838-981c-c4716a82d6e0'  // Energy Technology
];

// Fetch all standards for these categories
const { data: energyStandards, error: standardsError } = await supabase
  .from('standards')
  .select('id, code, name, description, category_id')
  .in('category_id', CATEGORY_IDS)
  .eq('is_active', true)
  .order('code');

// Primary Labs for the Hub (Saudi Tier-1)
const PRIMARY_LAB_IDS = [
  'a0b5ee02-6968-4e7b-8a4e-040e48ea9f61', // GCC Lab
  'e1e25686-165b-4f1e-9071-9d926a8bb299', // Al-Hoty Stanger
  '6a3e6873-459d-4be5-8897-e678ff273e29'  // ETLCO
];

// Fetch lab data and capabilities for the matrix
const { data: labsData, error: labsError } = await supabase
  .from('listings')
  .select(`
    id, 
    business_name,
    listing_capabilities(standard_id)
  `)
  .in('id', PRIMARY_LAB_IDS);

const matrixLabs = labsData?.map(lab => ({
  id: lab.id,
  business_name: lab.business_name,
  capabilities: lab.listing_capabilities.map(c => c.standard_id)
})) || [];

// Stats
const energyStandardIds = energyStandards?.map(s => s.id) || [];
let uniqueLabCount = 0;
if (energyStandardIds.length > 0) {
  const { data: totalLabs, error: totalError } = await supabase
    .from('listing_capabilities')
    .select('listing_id')
    .in('standard_id', energyStandardIds);
  uniqueLabCount = new Set(totalLabs?.map(l => l.listing_id) || []).size;
}

const title = "Saudi Energy Testing Hub | SASO & Aramco Certified Laboratory Network";
const description = "Discover and compare Tier-1 Saudi laboratories for renewable energy, power systems, and oil & gas infrastructure. Access ISO 17025 accredited facilities compliant with SASO and Aramco requirements.";
---

<BaseLayout title={title} description={description}>
  <div class="min-h-screen bg-primary text-text-primary selection:bg-tertiary/30 overflow-x-hidden">
    <!-- Hero Section -->
    <section class="relative pt-24 pb-20 px-6 overflow-hidden">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-tertiary/5 blur-[120px] rounded-full"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-accent/5 blur-[120px] rounded-full"></div>
      </div>

      <div class="max-w-7xl mx-auto relative z-10 text-center">
        <div class="inline-flex items-center px-4 py-2 rounded-full border border-tertiary/30 bg-tertiary/10 text-tertiary text-xs font-bold tracking-widest uppercase mb-8 animate-fade-up">
          <span class="relative flex h-2 w-2 mr-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-tertiary/40 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-tertiary"></span>
          </span>
          Kingdom of Saudi Arabia Energy Gateway
        </div>
        
        <h1 class="text-5xl md:text-7xl font-black mb-8 tracking-tighter leading-none animate-fade-up delay-100">
          The <span class="text-transparent bg-clip-text bg-gradient-to-r from-tertiary to-yellow-600">Saudi Energy</span> Hub
        </h1>
        
        <p class="max-w-2xl mx-auto text-lg md:text-xl text-text-secondary font-medium mb-12 animate-fade-up delay-200">
          Strategic access to mission-critical infrastructure testing. Accelerating Vision 2030 through verified laboratory excellence in Renewables, Power, and Material Integrity.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-fade-up delay-300">
          <a href="#matrix" class="px-8 py-4 rounded-xl bg-tertiary hover:bg-yellow-600 text-primary font-bold transition-all shadow-xl shadow-tertiary/20 active:scale-95">
            Compare KSA Laboratories
          </a>
          <a href="#rfq" class="px-8 py-4 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 text-white font-bold transition-all active:scale-95">
            Request Technical Proposal
          </a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-20 pt-10 border-t border-white/5 animate-fade-up delay-400">
          <div>
            <div class="text-3xl font-black text-white">{uniqueLabCount}</div>
            <div class="text-[10px] uppercase tracking-widest text-text-secondary mt-1">Verified Labs</div>
          </div>
          <div>
            <div class="text-3xl font-black text-white">{energyStandards?.length || 0}</div>
            <div class="text-[10px] uppercase tracking-widest text-text-secondary mt-1">Active Standards</div>
          </div>
          <div>
            <div class="text-3xl font-black text-white">VISION</div>
            <div class="text-[10px] uppercase tracking-widest text-text-secondary mt-1">2030 Aligned</div>
          </div>
          <div>
            <div class="text-3xl font-black text-white">SASO</div>
            <div class="text-[10px] uppercase tracking-widest text-text-secondary mt-1">Compliant Network</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Technical Matrix -->
    <section id="matrix" class="py-24 px-6 relative bg-secondary/30">
      <div class="max-w-7xl mx-auto">
        <div class="mb-16">
          <h2 class="text-3xl font-black mb-4 flex items-center gap-3">
            <span class="w-1.5 h-8 bg-tertiary rounded-full"></span>
            Technical Verification Matrix
          </h2>
          <p class="text-text-secondary max-w-xl font-medium">Comparative benchmarking of Tier-1 Saudi facilities against international and regional energy standards.</p>
        </div>
        
        <div class="animate-fade-up delay-500">
          <StandardMatrix client:load standards={energyStandards?.slice(0, 15) || []} labs={matrixLabs} />
        </div>
        
        <p class="mt-8 text-xs text-text-secondary italic">
          * Laboratory capabilities are verified against current ISO 17025 accreditation scopes.
        </p>
      </div>
    </section>

    <!-- Value Pillars -->
    <section class="py-24 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Renewables -->
          <div class="p-8 rounded-3xl border border-white/5 bg-secondary/50 backdrop-blur-sm group hover:border-tertiary/30 transition-all">
            <div class="w-12 h-12 rounded-2xl bg-tertiary/10 border border-tertiary/20 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-4">Renewable Infrastructure</h3>
            <p class="text-text-secondary text-sm leading-relaxed mb-6">PV module type approval (IEC 61215) and wind turbine design validation for the Saudi National Renewable Energy Program (NREP).</p>
            <a href="/search/standards?category=Renewable" class="text-tertiary text-sm font-bold flex items-center group-hover:gap-2 transition-all">
              Explore Standards <span class="ml-1">→</span>
            </a>
          </div>

          <!-- Power Systems -->
          <div class="p-8 rounded-3xl border border-white/5 bg-secondary/50 backdrop-blur-sm group hover:border-tertiary/30 transition-all">
            <div class="w-12 h-12 rounded-2xl bg-tertiary/10 border border-tertiary/20 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-4">Grid & Power Technology</h3>
            <p class="text-text-secondary text-sm leading-relaxed mb-6">High-voltage testing and smart grid certification. Supporting the modernization of the Saudi electricity network.</p>
            <a href="/search/standards?category=Power" class="text-tertiary text-sm font-bold flex items-center group-hover:gap-2 transition-all">
              Verify Grid Labs <span class="ml-1">→</span>
            </a>
          </div>

          <!-- Material Integrity -->
          <div class="p-8 rounded-3xl border border-white/5 bg-secondary/50 backdrop-blur-sm group hover:border-tertiary/30 transition-all">
            <div class="w-12 h-12 rounded-2xl bg-tertiary/10 border border-tertiary/20 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-4">Industrial Compliance</h3>
            <p class="text-text-secondary text-sm leading-relaxed mb-6">Non-destructive testing (NDT) and metallurgical analysis for Aramco projects and petrochemical infrastructure.</p>
            <a href="/search/standards?category=Testing" class="text-tertiary text-sm font-bold flex items-center group-hover:gap-2 transition-all">
              View Capabilities <span class="ml-1">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Vision 2030 Content Section -->
    <section class="py-24 px-6 max-w-4xl mx-auto">
      <div class="prose prose-invert max-w-none">
        <h2 class="text-3xl font-black mb-8 text-white">Unified Testing for a Transforming Kingdom</h2>
        <p class="text-text-secondary mb-6 font-medium leading-relaxed">
          As Saudi Arabia pivots towards a diversified energy mix, the demand for localized, world-class testing infrastructure has never been higher. The Saudi Energy Testing Hub bridges the gap between global standards and local project requirements.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-12">
          <div>
            <h4 class="text-tertiary font-bold mb-4 uppercase tracking-widest text-xs">Standardization</h4>
            <p class="text-sm text-text-secondary leading-relaxed">Direct mapping of SASO standards to international IEC and ISO equivalents, ensuring global export compatibility for Saudi-made energy components.</p>
          </div>
          <div>
            <h4 class="text-tertiary font-bold mb-4 uppercase tracking-widest text-xs">Local Content</h4>
            <p class="text-sm text-text-secondary leading-relaxed">Prioritizing IKTVA-aligned laboratory facilities to strengthen the domestic technical ecosystem and reduce project timelines.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Sticky RFQ Bar -->
    <div class="fixed bottom-0 left-0 right-0 z-[100] p-6 bg-gradient-to-t from-primary to-transparent pointer-events-none">
      <div class="max-w-4xl mx-auto pointer-events-auto">
        <div class="bg-secondary/90 backdrop-blur-xl border border-tertiary/20 rounded-2xl p-4 flex flex-col sm:flex-row items-center justify-between gap-4 shadow-2xl">
          <div class="hidden sm:block">
            <div class="text-sm font-bold text-white">Sourcing Saudi Lab Capabilities?</div>
            <div class="text-xs text-text-secondary">Request technical proposals from our verified network.</div>
          </div>
          <div class="flex gap-3 w-full sm:w-auto">
            <a href="#rfq" class="flex-1 sm:flex-none px-6 py-2.5 rounded-xl bg-tertiary text-primary text-sm font-black hover:bg-yellow-600 transition-all text-center">
              Submit Regional RFQ
            </a>
            <a href="/search/standards?region=Saudi+Arabia" class="flex-1 sm:flex-none px-6 py-2.5 rounded-xl bg-white/5 text-white text-sm font-bold hover:bg-white/10 border border-white/10 transition-all text-center">
              Global Directory
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Modals -->
    <ContactLabModal client:only="react" />

    <Footer />
  </div>
</BaseLayout>

<style is:global>
  body {
    background: #0a0a0b !important;
  }
  
  .animate-fade-up {
    animation: fade-up 0.5s ease-out forwards;
    opacity: 0;
  }
  
  .delay-100 { animation-delay: 0.1s; }
  .delay-200 { animation-delay: 0.2s; }
  .delay-300 { animation-delay: 0.3s; }
  .delay-400 { animation-delay: 0.4s; }
  .delay-500 { animation-delay: 0.5s; }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
