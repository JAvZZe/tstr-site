---
import { supabase } from '../../lib/supabase'
import { getRedirectUrl } from '../../lib/redirect'
import BaseLayout from '../../layouts/BaseLayout.astro'
import ContactLabModal from '../../components/ContactLabModal'
import AdUnit from '../../components/AdUnit.astro'

// Disable static prerendering for performance - use SSR instead
export const prerender = false

// Generate static paths for all active listings
export async function getStaticPaths() {
  const { data: listings, error } = await supabase
    .from('listings')
    .select('slug')
    .eq('status', 'active')
    .order('created_at', { ascending: false });

  if (error || !listings) {
    console.error('Error fetching listings for static paths:', error);
    return [];
  }

  return listings.map(listing => ({
    params: { slug: listing.slug }
  }));
}

const { slug } = Astro.params

// Fetch listing with location hierarchy and custom fields
const { data: listing, error } = await supabase
  .from('listings')
  .select(`
    *,
    category:category_id (
      id,
      name,
      slug
    ),
    location:location_id (
      id,
      name,
      slug,
      level,
      parent:parent_id (
        id,
        name,
        slug,
        level,
        parent:parent_id (
          id,
          name,
          slug,
          level
        )
      )
    ),
    premium_data:listing_premium_data (
      linkedin_url
    )
  `)
  .eq('slug', slug)
  .eq('status', 'active')
  .single()

if (error || !listing) {
  return Astro.redirect('/browse')
}

// Fetch custom field values
const { data: customFieldValues, error: _cfError } = await supabase
  .from('listing_custom_fields')
  .select(`
    value,
    custom_field:custom_field_id (
      field_name,
      field_type,
      field_label,
      options
    )
  `)
  .eq('listing_id', listing.id)

// Fetch listing capabilities (standards/certifications)
const { data: capabilities, error: _capError } = await supabase
  .from('listing_capabilities')
  .select(`
    standard:standard_id (
      code,
      name,
      description
    )
  `)
  .eq('listing_id', listing.id)
  .order('created_at', { ascending: true })

// Build location breadcrumb
const getLocationHierarchy = (location) => {
  if (!location) return []
  const hierarchy = []

  if (location.parent?.parent?.level === 'country') {
    hierarchy.push({ name: location.parent.parent.name, slug: location.parent.parent.slug, level: 'country' })
  }
  if (location.parent?.level === 'state') {
    hierarchy.push({ name: location.parent.name, slug: location.parent.slug, level: 'state' })
  }
  if (location.level === 'city') {
    hierarchy.push({ name: location.name, slug: location.slug, level: 'city' })
  }

  return hierarchy
}

const locationHierarchy = getLocationHierarchy(listing.location)
const country = locationHierarchy.find(l => l.level === 'country')

// Subscription tier system
let userTier = 'basic' 
let isLoggedIn = false

// Format custom fields by type
const formatFieldValue = (value, fieldType) => {
  if (fieldType === 'boolean') {
    return value ? 'Yes' : 'No'
  }
  if (fieldType === 'multi_select' && Array.isArray(value)) {
    return value.join(', ')
  }
  if (Array.isArray(value)) {
    return value.join(', ')
  }
  return value
}

const customFields = customFieldValues?.map(cf => ({
  name: cf.custom_field?.field_label || cf.custom_field?.field_name || 'Unknown',
  value: formatFieldValue(cf.value, cf.custom_field?.field_type),
  type: cf.custom_field?.field_type
})) || []

const standards = capabilities?.map(cap => ({
  name: cap.standard?.code || 'Unknown Standard',
  value: cap.standard?.name || 'Certification',
  type: 'standard'
})) || []

const allCertifications = [...customFields, ...standards]

import { formatTitle, formatDescription } from '../../lib/seo'

const locationParts = [
  listing.location?.name,
  listing.location?.parent?.name,
  listing.location?.parent?.parent?.name
].filter(Boolean);

const pageTitle = formatTitle([listing.business_name, ...locationParts]);
const pageDescription = formatDescription(
  listing.description || `${listing.business_name} is a verified testing laboratory and certification body. Access ISO 17025 accredited labs and testing services.`
);
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="max-w-6xl mx-auto px-4 py-8 md:py-12">
    
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-8 overflow-x-auto whitespace-nowrap pb-2 scrollbar-hide">
      <a href="/" class="hover:text-blue-400 transition-colors">Home</a>
      <span class="text-gray-600">/</span>
      <a href="/browse" class="hover:text-blue-400 transition-colors">Browse</a>
      {country && (
        <>
          <span class="text-gray-600">/</span>
          <a href={`/browse/${country.slug}`} class="hover:text-blue-400 transition-colors">{country.name}</a>
        </>
      )}
      <span class="text-gray-600">/</span>
      <span class="text-gray-200">{listing.business_name}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Main Content Column -->
      <div class="lg:col-span-2 space-y-8">
        
        <!-- Hero Section -->
        <div class="glass-panel p-8 relative overflow-hidden">
          <div class="absolute top-0 right-0 p-4">
             <div id="ownership-badge" class="hidden"></div>
          </div>
          
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div>
              <div class="flex items-center gap-3 mb-3">
                {listing.category?.name && (
                  <span class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 rounded-full text-xs font-semibold text-blue-400 uppercase tracking-wider">
                    {listing.category.name}
                  </span>
                )}
                {listing.featured && (
                  <span class="px-3 py-1 bg-amber-500/10 border border-amber-500/20 rounded-full text-xs font-semibold text-amber-400 uppercase tracking-wider">
                    Featured
                  </span>
                )}
              </div>
              <h1 class="text-3xl md:text-5xl font-black text-white mb-4 tracking-tight leading-tight">
                {listing.business_name}
              </h1>
              <div class="flex items-center gap-4 text-gray-400">
                 <span class="flex items-center gap-1.5">
                   <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                   {listing.location?.name || listing.region?.toUpperCase()}
                 </span>
                 {listing.verified && (
                   <span class="flex items-center gap-1.5 text-emerald-400 font-medium text-sm">
                     <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                     Verified Laboratory
                   </span>
                 )}
              </div>
            </div>
          </div>
        </div>

        <!-- About Section -->
        {listing.description && (
          <div class="glass-panel p-8">
            <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
              <span class="w-1.5 h-6 bg-blue-600 rounded-full"></span>
              Laboratory Profile
            </h2>
            <div class="prose prose-invert max-w-none text-gray-300 leading-relaxed text-lg">
              {listing.description}
            </div>
          </div>
        )}

        <!-- Capabilities section -->
        {allCertifications.length > 0 && (
          <div class="glass-panel p-8">
            <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
              <span class="w-1.5 h-6 bg-emerald-500 rounded-full"></span>
              Testing Capabilities & Standards
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {allCertifications.map(cert => (
                <div class="flex items-center justify-between p-4 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 transition-colors group">
                  <div>
                    <span class="text-xs font-bold text-gray-500 uppercase tracking-widest block mb-1">{cert.name}</span>
                    <span class="text-gray-200 group-hover:text-blue-400 transition-colors">{cert.value}</span>
                  </div>
                  {cert.type === 'standard' && (
                    <div class="w-8 h-8 rounded-lg bg-blue-600/20 flex items-center justify-center">
                      <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

      </div>

      <!-- Sidebar / Action Column -->
      <div class="space-y-6">
        
        <!-- Contact Card -->
        <div class="glass-panel p-6 border-blue-500/30">
          <h3 class="text-lg font-bold text-white mb-6">Connect with Laboratory</h3>
          
          <div class="space-y-4 mb-8">
             <div id="contact-info-container" class="space-y-4">
                {/* SSR View for SEO */}
                {listing.website && (
                  <div class="p-4 bg-white/5 border border-white/10 rounded-xl">
                    <span class="text-xs font-bold text-gray-500 uppercase tracking-widest block mb-1">Company Website</span>
                    <a 
                      href={getRedirectUrl(listing.website, listing.id)} 
                      target="_blank" 
                      rel="noopener noreferrer" 
                      onclick={`trackContactAccess('website', '${listing.website}')`}
                      class="text-blue-400 hover:text-blue-300 transition-colors break-all"
                    >
                      {listing.website}
                    </a>
                  </div>
                )}
                
                {listing.phone && (
                  <div id="phone-item" class="p-4 bg-white/5 border border-white/10 rounded-xl items-center justify-between flex">
                    <div>
                      <span class="text-xs font-bold text-gray-500 uppercase tracking-widest block mb-1">Direct Phone</span>
                      <span id="phone-value" class="text-gray-400 italic text-sm">Verified access required</span>
                    </div>
                    <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                  </div>
                )}

                {listing.email && (
                  <div id="email-item" class="p-4 bg-white/5 border border-white/10 rounded-xl items-center justify-between flex">
                    <div>
                      <span class="text-xs font-bold text-gray-500 uppercase tracking-widest block mb-1">Inquiry Email</span>
                      <span id="email-value" class="text-gray-400 italic text-sm">Verified access required</span>
                    </div>
                    <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                  </div>
                )}

                {listing.premium_data?.linkedin_url && (
                  <div class="p-4 bg-white/5 border border-white/10 rounded-xl flex items-center justify-between">
                    <div>
                      <span class="text-xs font-bold text-gray-500 uppercase tracking-widest block mb-1">Corporate LinkedIn</span>
                      <span class="text-gray-400 italic text-sm">Premium Feature</span>
                    </div>
                    <svg class="w-5 h-5 text-gray-600" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                  </div>
                )}
             </div>
          </div>
          
          <ContactLabModal client:visible listingId={listing.id} labName={listing.business_name} />
        </div>

        <!-- Claiming Card (Only shown if unclaimed / not logged in) -->
        <div id="claim-card-root" class="hidden">
           <div class="glass-panel p-6 border-emerald-500/20 bg-emerald-500/5">
              <h3 class="text-lg font-bold text-white mb-2">Own this Laboratory?</h3>
              <p class="text-gray-400 text-sm mb-6 leading-relaxed">
                Take control of your directory profile. Manage capabilities, respond to leads, and unlock premium analytics.
              </p>
              
              <div id="claim-action-area">
                <button id="claim-btn" class="w-full py-4 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-xl shadow-lg shadow-emerald-500/20 transition-all flex items-center justify-center gap-2">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                  Claim Profile Now
                </button>
              </div>

              <div id="claim-status-msg" class="hidden mt-4 p-3 rounded-lg text-sm"></div>
           </div>
        </div>

        <AdUnit slot="sidebar-bottom" type="vertical" />
      </div>
    </div>

    <!-- Concierge Fallback (Obsidian Standard) -->
    <div class="mt-12 group">
      <div class="glass-panel p-8 text-center border-blue-500/20 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-600/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <h3 class="text-2xl font-black text-white mb-4 tracking-tight">Need a custom testing solution?</h3>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto mb-8">
          Can't find the exact standard or facility? Our concierge team manually sources accredited partners for specialized engineering requirements.
        </p>
        <a 
          href={`mailto:expert@tstr.directory?subject=Concierge Search: ${encodeURIComponent(listing.business_name)}&body=I am looking for specialized testing services related to...`}
          class="inline-block py-4 px-10 bg-white text-black font-bold rounded-xl hover:scale-105 active:scale-95 transition-all shadow-xl shadow-white/10"
        >
          Request Free Concierge Search →
        </a>
      </div>
    </div>

    <AdUnit type="horizontal" class="mt-12" />
  </div>

  {/* Client-side Logic for Auth and Tracking */}
  <script is:inline src="https://haimjeaetrsaauitrhfy.supabase.co/auth/v1/callback"></script>
  <script>
    import { createClient } from '@supabase/supabase-js'
    
    // Use public anon key for browser-side checks
    const supabaseBrowser = createClient(
      import.meta.env.PUBLIC_SUPABASE_URL || 'https://haimjeaetrsaauitrhfy.supabase.co',
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY || 'sb_publishable_nFGCy-22_7FQlVr_SkJ6cQ_mwfYVhA4'
    )

    async function checkAuthAndClaimStatus() {
      try {
        const { data: { session } } = await supabaseBrowser.auth.getSession()
        const claimBadge = document.getElementById('ownership-badge')
        const claimCard = document.getElementById('claim-card-root')
        const claimBtn = document.getElementById('claim-btn')
        const claimStatus = document.getElementById('claim-status-msg')
        
        // 1. Fetch current claim status for this listing
        const { data: claims, error: claimError } = await supabaseBrowser
          .from('listing_claims')
          .select('status, user_id')
          .eq('listing_id', '{listing.id}')
          .maybeSingle()

        if (claimError) console.error('Error checking claim status:', claimError)

        // 2. UI Updates
        if (claims) {
          const info = getClaimStatusInfo(claims.status)
          if (claimBadge) {
             claimBadge.className = `flex items-center gap-1.5 px-3 py-1 bg-${info.color}-500/10 border border-${info.color}-500/20 rounded-full text-[10px] font-bold text-${info.color}-400 uppercase tracking-tighter`
             claimBadge.innerHTML = `<span class="w-1 h-1 rounded-full bg-${info.color}-400"></span> ${info.text}`
             claimBadge.style.display = 'flex'
          }
          
          if (claims.status === 'verified') {
             // Show full contact info if verified and owned by current user
             if (session?.user?.id === claims.user_id) {
               showOwnerContactInfo()
             }
          }
        } else {
          // Unclaimed: Show common claim CTA if not logged in or not verified owner
          if (claimCard) claimCard.classList.remove('hidden')
        }

        // 3. Claim Button Logic
        claimBtn?.addEventListener('click', async () => {
          if (!session) {
            window.location.href = `/login?redirect=${window.location.pathname}`
            return
          }

          const btn = claimBtn as HTMLButtonElement
          btn.disabled = true
          btn.innerHTML = '<span class="animate-pulse">Processing...</span>'

          const { error } = await supabaseBrowser
            .from('listing_claims')
            .insert([{
              listing_id: '{listing.id}',
              user_id: session.user.id,
              status: 'pending'
            }])

          if (!error) {
            if (claimStatus) {
              claimStatus.className = 'mt-4 p-4 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-xl'
              claimStatus.innerHTML = '<strong>Success:</strong> Your claim request has been submitted for verification.'
              claimStatus.classList.remove('hidden')
            }
            if (btn.parentElement) btn.parentElement.style.display = 'none'
          } else {
            console.error('Claim error:', error)
            if (claimStatus) {
               claimStatus.className = 'mt-4 p-4 bg-red-500/10 border border-red-500/20 text-red-400 rounded-xl'
               claimStatus.innerHTML = `<strong>Error:</strong> ${error.message}`
               claimStatus.classList.remove('hidden')
            }
            btn.disabled = false
            btn.innerHTML = 'Claim Profile Now'
          }
        })

      } catch (error) {
        console.error('Auth/Claim check failed:', error)
      }
    }

    function getClaimStatusInfo(status: string) {
      switch (status) {
        case 'verified': return { text: 'Verified Owner', color: 'emerald' }
        case 'pending': return { text: 'Claim Pending', color: 'amber' }
        case 'rejected': return { text: 'Claim Rejected', color: 'red' }
        default: return { text: 'Not Claimed', color: 'gray' }
      }
    }

    (window as any).trackContactAccess = async function(contactType: string, contactValue: string) {
      try {
        await fetch('/api/leads/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            listingId: '{listing.id}',
            contactType: contactType,
            contactValue: contactValue
          })
        })
      } catch (e) { console.warn('Lead tracking failed:', e) }
    }

    function showOwnerContactInfo() {
      // Logic to swap dummy placeholders with real data already fetched via SSR
      // and expose it to the verified owner
      const phoneItem = document.getElementById('phone-item')
      const emailItem = document.getElementById('email-item')
      
      if (phoneItem && '{listing.phone}') {
         const val = document.getElementById('phone-value')
         if (val) {
           val.innerHTML = `<a href="tel:{listing.phone}" class="text-blue-400">{listing.phone}</a>`
           val.classList.remove('italic', 'text-gray-400')
         }
      }
      
      if (emailItem && '{listing.email}') {
         const val = document.getElementById('email-value')
         if (val) {
           val.innerHTML = `<a href="mailto:{listing.email}" class="text-blue-400">{listing.email}</a>`
           val.classList.remove('italic', 'text-gray-400')
         }
      }
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', checkAuthAndClaimStatus)
  </script>

</BaseLayout>
