---
import { supabase } from '../lib/supabase'
import BaseLayout from '../layouts/BaseLayout.astro'
import { formatTitle, formatDescription } from '../lib/seo';

// Fetch total active listings count
const { count: totalListings } = await supabase
  .from('listings')
  .select('*', { count: 'exact', head: true })
  .eq('status', 'active');


// Fetch counts for core industry pillars (any category with a description)
const { data: categoryData } = await supabase
  .from('categories')
  .select(`
    name,
    slug,
    description,
    listings:listings!category_id(count)
  `)
  .not('description', 'is', null)
  .order('name');

const PILLARS_CONFIG = {
  'hydrogen-infrastructure-testing': { icon: '⚡', color: '#60a5fa' }, // Blue
  'materials-testing': { icon: '🔬', color: '#34d399' }, // Emerald
  'environmental-testing': { icon: '🌿', color: '#10b981' }, 
  'pharmaceutical-testing': { icon: '🧬', color: '#a78bfa' },
  'oil-gas-testing': { icon: '🛢️', color: '#fbbf24' },
  'biotech-testing': { icon: '🧫', color: '#f472b6' },
  'aerospace-testing': { icon: '🚀', color: '#60a5fa' },
  'ev-battery-testing': { icon: '🔋', color: '#34d399' },
  'railway-testing': { icon: '🚆', color: '#818cf8' },
  'cybersecurity-testing': { icon: '🛡️', color: '#94a3b8' },
  'telecom-5g-testing': { icon: '📶', color: '#a78bfa' },
  'nuclear-testing': { icon: '☢️', color: '#facc15' },
  'building-construction-testing': { icon: '🏗️', color: '#f87171' },
  'mining-geochemistry-testing': { icon: '⛏️', color: '#a3e635' },
  'defense-ballistics-testing': { icon: '🎯', color: '#475569' },
  'acoustics-vibration-testing': { icon: '🔊', color: '#22d3ee' },
  'product-safety-emc-testing': { icon: '🔌', color: '#fb923c' },
  'calibration-metrology-services': { icon: '📏', color: '#94a3b8' }
};

const pillars = categoryData?.map(cat => ({
  slug: cat.slug,
  label: cat.name.replace(' Testers', '').replace(' Testing', '').replace(' Services', ''),
  icon: PILLARS_CONFIG[cat.slug]?.icon || '🔬',
  color: PILLARS_CONFIG[cat.slug]?.color || '#94a3b8',
  description: cat.description?.split('.')[0] + '.',
  count: cat.listings?.[0]?.count || 0
})).filter(p => p.count > 0) || [];


// Fetch top 4 recently verified/claimed labs
const { data: featuredLabs } = await supabase
  .from('listings')
  .select('business_name, slug, region, trust_score, claimed')
  .eq('status', 'active')
  .eq('claimed', true)
  .order('trust_score', { ascending: false })
  .limit(4);

// Optimized SEO parts
const pageTitle = formatTitle(['Specialist Testing Services Directory'], true);
const pageDescription = formatDescription(
  `Find and compare ${totalListings || 200} verified Testers and certification bodies worldwide. AI-powered search for materials, environmental, and hydrogen testing.`
);
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- HERO: AI Search Section -->
  <section id="hero-search" class="relative pt-32 pb-24 px-6 text-center overflow-hidden">
    <div class="relative z-10 max-w-4xl mx-auto animate-fade-up">
      <h1 class="text-white text-5xl md:text-7xl font-black mb-6 tracking-tight leading-[0.9]">
        The global directory for<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400">specialist testing</span>
      </h1>
      <p class="text-slate-400 text-xl md:text-2xl mb-12 font-medium max-w-2xl mx-auto">
        Find and compare {totalListings || 200}+ verified Testers internationally
      </p>
      
      <!-- Search bar UI -->
      <div id="search-container" class="relative max-w-2xl mx-auto">
        <div class="flex gap-2 bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-2 shadow-2xl shadow-blue-500/10">
          <div class="flex-1 bg-white/[0.03] rounded-xl flex items-center px-4 border border-white/5">
            <span class="text-2xl opacity-50 mr-3">🔍</span>
            <input
              type="text"
              id="ai-search-input"
              placeholder="Searching for Testers..."
              autocomplete="off"
              class="w-full bg-transparent border-none outline-none text-white text-lg py-4 font-medium placeholder:text-slate-600"
            />
          </div>
          <button id="ai-search-btn" class="bg-blue-600 hover:bg-blue-500 text-white px-8 rounded-xl font-black text-lg transition-all active:scale-95 shadow-lg shadow-blue-600/20">
            Search
          </button>
        </div>
        
        <!-- Results dropdown -->
        <div id="search-results" class="hidden absolute top-full left-0 right-0 mt-4 glass-panel rounded-2xl shadow-3xl z-[100] max-height-[480px] overflow-y-auto text-left">
        </div>
      </div>
      
      <!-- Rotating placeholder examples -->
      <p id="example-query" class="text-slate-500 text-sm mt-6 font-mono transition-opacity duration-500"></p>
    </div>
  </section>

  <!-- PILLARS: Industry Sectors -->
  <section class="py-24 px-6 max-w-7xl mx-auto relative">
    <div class="text-center mb-16 animate-fade-up delay-100">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4 tracking-tight">Browse by Sector</h2>
      <div class="w-12 h-1 bg-blue-500 mx-auto rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {pillars.map((p, i) => (
        <a href={`/browse?category=${p.slug}`} class={`animate-fade-up`} style={`animation-delay: ${150 + (i * 50)}ms`}>
          <div class="glass-card glass-card-hover h-full p-8 group relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br opacity-0 group-hover:opacity-10 transition-opacity duration-500" style={`from-transparent to-[${p.color}]`}></div>
            <div class="text-4xl mb-6 transform group-hover:scale-110 transition-transform duration-300">{p.icon}</div>
            <h3 class="text-xl font-black text-white mb-2 tracking-tight group-hover:text-glow-blue transition-all" style={`color: ${p.color}`}>{p.label}</h3>
            <p class="text-slate-400 text-sm mb-6 leading-relaxed flex-grow">{p.description}</p>
            <div class="flex items-center gap-2 font-bold text-xs uppercase tracking-widest opacity-60 group-hover:opacity-100 transition-opacity" style={`color: ${p.color}`}>
              <span>{p.count} Testers</span>
              <span class="transform group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- RECENTLY VERIFIED STRIP -->
  {featuredLabs && featuredLabs.length > 0 && (
    <section class="glass-panel py-16 px-6">
      <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center justify-between gap-12">
        <div class="max-w-md text-center lg:text-left">
          <h2 class="text-2xl font-black text-white mb-2 tracking-tight">Top Verified Testers</h2>
          <p class="text-slate-500 font-medium">Directly certified and high-trust Testers added this month.</p>
        </div>
        <div class="flex-1 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 w-full">
          {featuredLabs.map(lab => (
            <a href={`/listing/${lab.slug}`} class="glass-card p-5 group hover:bg-white/[0.05] border-white/5 transition-all">
              <div class="text-[10px] font-black text-emerald-400 mb-2 tracking-widest uppercase">Verified</div>
              <div class="font-bold text-white text-sm mb-1 truncate group-hover:text-blue-400 transition-colors">{lab.business_name}</div>
              <div class="text-slate-500 text-xs font-medium">{lab.region}</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FINAL CTAs -->
  <section class="py-32 px-6 text-center relative overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-blue-600/5 blur-[120px] rounded-full z-0"></div>
    <div class="relative z-10 animate-fade-up">
      <h2 class="text-4xl md:text-5xl font-black text-white mb-12 tracking-tighter">Ready to Start?</h2>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/submit" class="bg-blue-600 hover:bg-blue-500 text-white px-10 py-5 rounded-2xl font-black text-xl transition-all shadow-xl shadow-blue-600/20 active:scale-95">
          List Your Tester Profile Free
        </a>
        <a href="/search/standards" class="bg-white/5 hover:bg-white/10 text-white border border-white/10 px-10 py-5 rounded-2xl font-black text-xl transition-all active:scale-95">
          Search by ISO Standard
        </a>
      </div>
      <p class="mt-8 text-slate-500 font-bold uppercase tracking-widest text-xs">Join {totalListings || 200}+ specialist Testers on TSTR.directory</p>
    </div>
  </section>

  <script>
    // --- AI SEARCH WIDGET ---
    const input = document.getElementById('ai-search-input');
    const resultsDiv = document.getElementById('search-results');
    const searchBtn = document.getElementById('ai-search-btn');
    const exampleEl = document.getElementById('example-query');

    const debounce = (fn, ms) => {
      let t;
      return (...args) => {
        clearTimeout(t);
        t = setTimeout(() => fn(...args), ms);
      };
    };

    const examples = [
      '"hydrogen infrastructure testing"',
      '"ISO 19880-3 valve certification"',
      '"water quality analysis Germany"',
      '"materials fatigue testers UK"',
      '"ISO 17025 accredited testers"',
      '"biopharma clinical testers USA"',
      '"oil and gas pipeline inspection"'
    ];
    let exIdx = 0;
    
    // Function to cycle placeholder examples
    const cycleExample = () => {
      if (!input || !exampleEl) return;
      if (document.activeElement === input) {
        exampleEl.textContent = 'Press Enter to see all results';
        return;
      }
      exampleEl.style.opacity = '0';
      setTimeout(() => {
        exampleEl.textContent = `Try searching ${examples[exIdx % examples.length]}...`;
        exampleEl.style.opacity = '1';
        input.placeholder = examples[exIdx % examples.length].replace(/"/g, '');
        exIdx++;
      }, 500);
    };

    setInterval(cycleExample, 4000);
    cycleExample();

    const doSearch = async (query) => {
      if (!query || query.length < 2) {
        resultsDiv.style.display = 'none';
        return;
      }

      resultsDiv.innerHTML = '<div style="padding: 2rem; text-align: center; color: #64748b; font-weight: 500;">🔍 Analyzing intent...</div>';
      resultsDiv.style.display = 'block';

      try {
        const res = await fetch('/api/ai-search', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ query })
        });
        const data = await res.json();
        
        if (!data.results?.length) {
          resultsDiv.innerHTML = `
            <div style="padding: 2rem; text-align: center;">
              <p style="color: #64748b; margin-bottom: 1rem;">No direct matches found for "${query}"</p>
              <a href="/browse?q=${encodeURIComponent(query)}" style="color: #000080; font-weight: 700; text-decoration: none; border-bottom: 2px solid #32CD32;">Try manual browse &rarr;</a>
            </div>`;
          return;
        }

        const modeBadge = data.search_mode?.startsWith('ai') 
          ? '<span style="background: #f0fdf4; color: #166534; padding: 4px 10px; border-radius: 99px; font-size: 0.75rem; font-weight: 700;">✨ AI Intent Found</span>' 
          : '';

        const resultsHtml = data.results.map(r => `
          <a href="/listing/${r.slug}" style="display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 1.5rem; text-decoration: none; border-bottom: 1px solid #f1f5f9; transition: background 0.15s;">
            <div style="flex: 1; min-width: 0;">
              <div style="font-weight: 800; color: #0f172a; font-size: 1.1rem; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${r.business_name}</div>
              <div style="display: flex; align-items: center; gap: 8px; font-size: 0.85rem; color: #64748b;">
                <span style="background: #f8fafc; padding: 2px 8px; border-radius: 4px; border: 1px solid #e2e8f0;">${r.category_name}</span>
                <span>${r.region || 'International'}</span>
              </div>
            </div>
            <div style="text-align: right; flex-shrink: 0; margin-left: 1rem;">
              ${r.claimed ? '<div style="color: #16a34a; font-size: 0.75rem; font-weight: 900;">✓ VERIFIED</div>' : ''}
              ${r.trust_score ? `<div style="color: #94a3b8; font-size: 0.75rem; font-weight: 600;">Score ${r.trust_score}</div>` : ''}
            </div>
          </a>
        `).join('');

        resultsDiv.innerHTML = `
          <div style="padding: 0.75rem 1.5rem; background: #f8fafc; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
            <span style="font-size: 0.85rem; font-weight: 600; color: #64748b;">Found ${data.total} matches</span>
            ${modeBadge}
          </div>
          ${resultsHtml}
          <a href="/browse?q=${encodeURIComponent(query)}" style="display: block; padding: 1.25rem; text-align: center; color: #000080; font-weight: 800; font-size: 1rem; border-top: 1px solid #e2e8f0; background: white; transition: background 0.2s;">
            See all ${data.total} results &rarr;
          </a>
        `;
      } catch (err) {
        console.error('Search failed:', err);
        resultsDiv.innerHTML = '<div style="padding: 2rem; color: #ef4444; font-weight: 600;">⚠️ Search is temporarily unavailable.</div>';
      }
    };

    const debouncedSearch = debounce(doSearch, 400);

    input?.addEventListener('input', (e) => debouncedSearch(e.target.value));
    
    searchBtn?.addEventListener('click', () => {
      const q = input.value.trim();
      if (q) window.location.href = `/browse?q=${encodeURIComponent(q)}`;
    });

    input?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') searchBtn.click();
      if (e.key === 'Escape') resultsDiv.style.display = 'none';
    });

    // Hide dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (!e.target.closest('#search-container')) {
        resultsDiv.style.display = 'none';
      }
    });

    // Interaction tracking or other init
    input?.addEventListener('focus', () => {
      if (input.value.length >= 2) resultsDiv.style.display = 'block';
    });
  </script>
</BaseLayout>
