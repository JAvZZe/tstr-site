---
import { supabase } from '../lib/supabase'
import Footer from '../components/Footer.astro'
import Header from '../components/Header.astro'
import { formatTitle, formatDescription } from '../lib/seo';

// Fetch total active listings count
const { count: totalListings } = await supabase
  .from('listings')
  .select('*', { count: 'exact', head: true })
  .eq('status', 'active');


// Fetch counts for core industry pillars (any category with a description)
const { data: categoryData } = await supabase
  .from('categories')
  .select(`
    name,
    slug,
    description,
    listings:listings!category_id(count)
  `)
  .not('description', 'is', null)
  .order('name');

const PILLARS_CONFIG = {
  'hydrogen-infrastructure-testing': { icon: '⚡', color: '#0066cc' },
  'materials-testing': { icon: '🔬', color: '#166534' },
  'environmental-testing': { icon: '🌿', color: '#065f46' },
  'pharmaceutical-testing': { icon: '🧬', color: '#6b21a8' },
  'oil-gas-testing': { icon: '🛢️', color: '#b45309' },
  'biotech-testing': { icon: '🧫', color: '#be185d' },
  'aerospace-testing': { icon: '🚀', color: '#1e40af' },
  'ev-battery-testing': { icon: '🔋', color: '#15803d' },
  'railway-testing': { icon: '🚆', color: '#4338ca' },
  'cybersecurity-testing': { icon: '🛡️', color: '#334155' },
  'telecom-5g-testing': { icon: '📶', color: '#7c3aed' },
  'nuclear-testing': { icon: '☢️', color: '#ca8a04' },
  'building-construction-testing': { icon: '🏗️', color: '#b91c1c' },
  'mining-geochemistry-testing': { icon: '⛏️', color: '#4d7c0f' },
  'defense-ballistics-testing': { icon: '🎯', color: '#111827' },
  'acoustics-vibration-testing': { icon: '🔊', color: '#0891b2' },
  'product-safety-emc-testing': { icon: '🔌', color: '#ea580c' },
  'calibration-metrology-services': { icon: '📏', color: '#475569' }
};

const pillars = categoryData?.map(cat => ({
  slug: cat.slug,
  label: cat.name.replace(' Testers', '').replace(' Testing', '').replace(' Services', ''),
  icon: PILLARS_CONFIG[cat.slug]?.icon || '🔬',
  color: PILLARS_CONFIG[cat.slug]?.color || '#475569',
  description: cat.description?.split('.')[0] + '.',
  count: cat.listings?.[0]?.count || 0
})).filter(p => p.count > 0) || [];


// Fetch top 4 recently verified/claimed labs
const { data: featuredLabs } = await supabase
  .from('listings')
  .select('business_name, slug, region, trust_score, claimed')
  .eq('status', 'active')
  .eq('claimed', true)
  .order('trust_score', { ascending: false })
  .limit(4);

// Optimized SEO parts
const pageTitle = formatTitle(['Specialist Testing Services Directory'], true);
const pageDescription = formatDescription(
  `Find and compare ${totalListings || 200} verified testing laboratories and certification bodies worldwide. AI-powered search for materials, environmental, and hydrogen testing.`
);


---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://tstr.directory" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      line-height: 1.6;
      color: #1e293b;
      background: #f8fafc;
    }
    main { width: 100%; }
    
    .pillar-card {
      background: white;
      border-radius: 16px;
      padding: 2rem;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      cursor: pointer;
      display: flex;
      flex-direction: column;
      height: 100%;
    }
    .pillar-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }
    
    .cta-button {
      display: inline-block;
      background: #000080;
      color: white;
      padding: 0.875rem 2rem;
      border-radius: 12px;
      text-decoration: none;
      font-weight: 700;
      transition: all 0.2s;
    }
    .cta-button:hover {
      background: #32CD32;
      transform: translateY(-2px);
    }

    #search-results a:last-child { border-bottom: none; }
    
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    #search-results {
      animation: fadeIn 0.2s ease-out;
    }
  </style>
</head>
<body>
  <Header showHero={false} />

  <main>
    <!-- HERO: AI Search Section -->
    <section id="hero-search" style="background: linear-gradient(135deg, #000033 0%, #000080 100%); padding: 6rem 1.5rem 5rem; text-align: center; position: relative; overflow: hidden;">
      <!-- Subtle background decoration -->
      <div style="position: absolute; top: -10%; right: -5%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(50, 205, 50, 0.15) 0%, transparent 70%); border-radius: 50%;"></div>
      <div style="position: absolute; bottom: -10%; left: -5%; width: 300px; height: 300px; background: radial-gradient(circle, rgba(0, 102, 204, 0.2) 0%, transparent 70%); border-radius: 50%;"></div>

      <div style="position: relative; z-index: 10; max-width: 900px; margin: 0 auto;">
        <h1 style="color: white; font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 900; margin-bottom: 1.5rem; line-height: 1.1; letter-spacing: -0.02em;">
          The global directory for<br/>specialist testing
        </h1>
        <p style="color: rgba(255,255,255,0.85); font-size: 1.25rem; margin-bottom: 3rem; font-weight: 500;">
          Find and compare {totalListings || 200}+ verified laboratories internationally
        </p>
        
        <!-- Search bar UI -->
        <div id="search-container" style="position: relative; max-width: 750px; margin: 0 auto;">
          <div style="display: flex; gap: 8px; background: rgba(255,255,255,0.1); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.2); border-radius: 20px; padding: 8px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);">
            <div style="flex: 1; background: white; border-radius: 14px; display: flex; align-items: center; padding: 0 16px;">
              <span style="font-size: 1.4rem; opacity: 0.5;">🔍</span>
              <input
                type="text"
                id="ai-search-input"
                placeholder="Searching for labs..."
                autocomplete="off"
                style="width: 100%; border: none; outline: none; font-size: 1.15rem; padding: 1.1rem 0.75rem; border-radius: 10px; font-family: inherit; font-weight: 500;"
              />
            </div>
            <button id="ai-search-btn" style="background: #32CD32; color: white; border: none; border-radius: 14px; padding: 0 2rem; font-size: 1.1rem; font-weight: 800; cursor: pointer; transition: all 0.2s;">
              Search
            </button>
          </div>
          
          <!-- Results dropdown -->
          <div id="search-results" style="display: none; position: absolute; top: calc(100% + 12px); left: 0; right: 0; background: white; border-radius: 20px; box-shadow: 0 30px 60px -12px rgba(0,0,0,0.3); z-index: 1000; max-height: 480px; overflow-y: auto; text-align: left; border: 1px solid #e2e8f0;">
          </div>
        </div>
        
        <!-- Rotating placeholder examples -->
        <p id="example-query" style="color: rgba(255,255,255,0.5); font-size: 0.95rem; margin-top: 1.5rem; font-weight: 500; min-height: 1.5em;"></p>
      </div>
    </section>

    <!-- PILLARS: Industry Sectors -->
    <section style="padding: 5rem 1.5rem; max-width: 1240px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 4rem;">
        <h2 style="font-size: 2.25rem; font-weight: 800; color: #0f172a; margin-bottom: 1rem;">Browse by sector</h2>
        <div style="width: 60px; height: 4px; background: #32CD32; margin: 0 auto; border-radius: 2px;"></div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 2rem;">
        {PILLARS.map(p => (
          <a href={`/browse?category=${p.slug}`} style="text-decoration: none; color: inherit;">
            <div class="pillar-card" style={`border-top: 6px solid ${p.color};`}>
              <div style="font-size: 2.5rem; margin-bottom: 1.5rem;">{p.icon}</div>
              <h3 style="font-size: 1.5rem; font-weight: 800; color: #1e293b; margin-bottom: 0.5rem;">{p.label}</h3>
              <p style="color: #64748b; font-size: 1rem; margin-bottom: 1.5rem; flex-grow: 1;">{p.description}</p>
              <div style={`display: flex; align-items: center; gap: 8px; font-weight: 700; color: ${p.color}; font-size: 0.95rem;`}>
                <span>{catCounts[p.slug] || 0} laboratories</span>
                <span>→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- RECENTLY VERIFIED STRIP -->
    {featuredLabs && featuredLabs.length > 0 && (
      <section style="background: #0f172a; color: white; padding: 4rem 1.5rem;">
        <div style="max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 2rem;">
          <div style="max-width: 400px;">
            <h2 style="color: white; border: none; font-size: 1.8rem; margin-bottom: 0.5rem;">Top Verified Labs</h2>
            <p style="color: #94a3b8; font-size: 1rem;">Directly certified and high-trust laboratories added this month.</p>
          </div>
          <div style="flex: 1; display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.5rem;">
            {featuredLabs.map(lab => (
              <a href={`/listing/${lab.slug}`} style="text-decoration: none; color: inherit; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 1.25rem; transition: background 0.2s;">
                <div style="font-weight: 700; color: #32CD32; font-size: 0.85rem; margin-bottom: 0.5rem;">★ TRUSTED</div>
                <div style="font-weight: 600; font-size: 1.05rem; margin-bottom: 0.25rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{lab.business_name}</div>
                <div style="color: #94a3b8; font-size: 0.85rem;">{lab.region}</div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- FINAL CTAs -->
    <section style="padding: 6rem 1.5rem; text-align: center; background: white;">
      <h2 style="border: none; font-size: 2.5rem; margin-bottom: 3rem;">Ready to start?</h2>
      <div style="display: flex; justify-content: center; gap: 1.5rem; flex-wrap: wrap;">
        <a href="/submit" class="cta-button" style="padding: 1.25rem 3rem; font-size: 1.2rem;">List Your Lab Free</a>
        <a href="/search/standards" class="cta-button" style="padding: 1.25rem 3rem; font-size: 1.2rem; background: #0f172a;">Search by ISO Standard</a>
      </div>
      <p style="margin-top: 2rem; color: #64748b; font-weight: 500;">Join {totalListings || 200}+ specialist laboratories on TSTR.directory</p>
    </section>
  </main>

  <Footer />

  <script>
    // --- AI SEARCH WIDGET ---
    const input = document.getElementById('ai-search-input');
    const resultsDiv = document.getElementById('search-results');
    const searchBtn = document.getElementById('ai-search-btn');
    const exampleEl = document.getElementById('example-query');

    const debounce = (fn, ms) => {
      let t;
      return (...args) => {
        clearTimeout(t);
        t = setTimeout(() => fn(...args), ms);
      };
    };

    const examples = [
      '"hydrogen infrastructure testing"',
      '"ISO 19880-3 valve certification"',
      '"water quality analysis Germany"',
      '"materials fatigue labs UK"',
      '"ISO 17025 accredited testers"',
      '"biopharma clinical labs USA"',
      '"oil and gas pipeline inspection"'
    ];
    let exIdx = 0;
    
    // Function to cycle placeholder examples
    const cycleExample = () => {
      if (!input || !exampleEl) return;
      if (document.activeElement === input) {
        exampleEl.textContent = 'Press Enter to see all results';
        return;
      }
      exampleEl.style.opacity = '0';
      setTimeout(() => {
        exampleEl.textContent = `Try searching ${examples[exIdx % examples.length]}...`;
        exampleEl.style.opacity = '1';
        input.placeholder = examples[exIdx % examples.length].replace(/"/g, '');
        exIdx++;
      }, 500);
    };

    setInterval(cycleExample, 4000);
    cycleExample();

    const doSearch = async (query) => {
      if (!query || query.length < 2) {
        resultsDiv.style.display = 'none';
        return;
      }

      resultsDiv.innerHTML = '<div style="padding: 2rem; text-align: center; color: #64748b; font-weight: 500;">🔍 Analyzing intent...</div>';
      resultsDiv.style.display = 'block';

      try {
        const res = await fetch('/api/ai-search', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ query })
        });
        const data = await res.json();
        
        if (!data.results?.length) {
          resultsDiv.innerHTML = `
            <div style="padding: 2rem; text-align: center;">
              <p style="color: #64748b; margin-bottom: 1rem;">No direct matches found for "${query}"</p>
              <a href="/browse?q=${encodeURIComponent(query)}" style="color: #000080; font-weight: 700; text-decoration: none; border-bottom: 2px solid #32CD32;">Try manual browse &rarr;</a>
            </div>`;
          return;
        }

        const modeBadge = data.search_mode?.startsWith('ai') 
          ? '<span style="background: #f0fdf4; color: #166534; padding: 4px 10px; border-radius: 99px; font-size: 0.75rem; font-weight: 700;">✨ AI Intent Found</span>' 
          : '';

        const resultsHtml = data.results.map(r => `
          <a href="/listing/${r.slug}" style="display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 1.5rem; text-decoration: none; border-bottom: 1px solid #f1f5f9; transition: background 0.15s;">
            <div style="flex: 1; min-width: 0;">
              <div style="font-weight: 800; color: #0f172a; font-size: 1.1rem; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${r.business_name}</div>
              <div style="display: flex; align-items: center; gap: 8px; font-size: 0.85rem; color: #64748b;">
                <span style="background: #f8fafc; padding: 2px 8px; border-radius: 4px; border: 1px solid #e2e8f0;">${r.category_name}</span>
                <span>${r.region || 'International'}</span>
              </div>
            </div>
            <div style="text-align: right; flex-shrink: 0; margin-left: 1rem;">
              ${r.claimed ? '<div style="color: #16a34a; font-size: 0.75rem; font-weight: 900;">✓ VERIFIED</div>' : ''}
              ${r.trust_score ? `<div style="color: #94a3b8; font-size: 0.75rem; font-weight: 600;">Score ${r.trust_score}</div>` : ''}
            </div>
          </a>
        `).join('');

        resultsDiv.innerHTML = `
          <div style="padding: 0.75rem 1.5rem; background: #f8fafc; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
            <span style="font-size: 0.85rem; font-weight: 600; color: #64748b;">Found ${data.total} matches</span>
            ${modeBadge}
          </div>
          ${resultsHtml}
          <a href="/browse?q=${encodeURIComponent(query)}" style="display: block; padding: 1.25rem; text-align: center; color: #000080; font-weight: 800; font-size: 1rem; border-top: 1px solid #e2e8f0; background: white; transition: background 0.2s;">
            See all ${data.total} results &rarr;
          </a>
        `;
      } catch (err) {
        console.error('Search failed:', err);
        resultsDiv.innerHTML = '<div style="padding: 2rem; color: #ef4444; font-weight: 600;">⚠️ Search is temporarily unavailable.</div>';
      }
    };

    const debouncedSearch = debounce(doSearch, 400);

    input?.addEventListener('input', (e) => debouncedSearch(e.target.value));
    
    searchBtn?.addEventListener('click', () => {
      const q = input.value.trim();
      if (q) window.location.href = `/browse?q=${encodeURIComponent(q)}`;
    });

    input?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') searchBtn.click();
      if (e.key === 'Escape') resultsDiv.style.display = 'none';
    });

    // Hide dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (!e.target.closest('#search-container')) {
        resultsDiv.style.display = 'none';
      }
    });

    // Interaction tracking or other init
    input?.addEventListener('focus', () => {
      if (input.value.length >= 2) resultsDiv.style.display = 'block';
    });
  </script>
</body>
</html>
