---
// src/pages/environmental-testing/water-quality/index.astro
import { supabase } from '../../../lib/supabase';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AdUnit from '../../../components/AdUnit.astro';
import { formatTitle, formatDescription } from '../../../lib/seo';

// Enable static prerendering at build time
export const prerender = true;

// Page metadata
const subcategory = 'water-quality';
const subcategoryName = 'Water Quality Testing';
const subcategoryDescription = 'Drinking water testing, wastewater analysis, and groundwater monitoring services';

// Fetch category metadata (environmental-testing)
const { data: categoryData } = await supabase
  .from('categories')
  .select('id, name, slug, description, icon')
  .eq('slug', 'environmental-testing')
  .single();

if (!categoryData) {
  return Astro.redirect('/404');
}

// Fetch listings with custom fields for water quality testing
const { data: listings, error: listingsError } = await supabase
  .from('listings')
  .select(`
    id,
    business_name,
    region,
    featured,
    verified,
    location:location_id (
      id,
      name,
      slug
    ),
    listing_custom_field_values (
      custom_field_id,
      value,
      custom_fields (
        name
      )
    )
  `)
  .eq('status', 'active')
  .eq('category_id', categoryData.id)
  .order('priority_rank', { ascending: false })
  .order('created_at', { ascending: false });

// Filter listings that have water quality testing
const waterQualityListings = listings?.filter(listing => {
  return listing.listing_custom_field_values?.some(field => {
    return field.custom_fields?.name === 'test_types' &&
           (field.value?.toLowerCase().includes('water quality') ||
            field.value?.toLowerCase().includes('drinking water') ||
            field.value?.toLowerCase().includes('wastewater'));
  });
}) || [];

// Group filtered listings by region
const listingsByRegion = new Map<string, typeof waterQualityListings>();
waterQualityListings.forEach(listing => {
  const region = listing.region || 'global';
  if (!listingsByRegion.has(region)) {
    listingsByRegion.set(region, []);
  }
  listingsByRegion.get(region)?.push(listing);
});

// Sort regions by listing count (descending)
const sortedRegions = Array.from(listingsByRegion.entries())
  .sort((a, b) => b[1].length - a[1].length);

const totalListings = waterQualityListings.length;

// Helper: Convert "Testers" to "Testing" for SEO hybrid hook
const getTestingServiceName = (categoryName: string) => {
  return categoryName.replace('Testers', 'Testing');
};

const testingServiceName = getTestingServiceName(categoryData.name);

// Optimized SEO
const pageTitle = formatTitle([subcategoryName, testingServiceName]);
const pageDescription = formatDescription(
  `Directory of ${totalListings} verified ${subcategoryName.toLowerCase()} and ${testingServiceName.toLowerCase()}. Compare ISO 17025 accredited water testing labs and drinking water analysis services.`
);
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="max-w-7xl mx-auto px-6 py-12">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm font-medium text-slate-500 mb-8 overflow-x-auto whitespace-nowrap pb-2 no-scrollbar">
      <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
      <span class="text-slate-700">/</span>
      <a href="/environmental-testing" class="hover:text-emerald-400 transition-colors">{categoryData.name}</a>
      <span class="text-slate-700">/</span>
      <span class="text-white">{subcategoryName}</span>
    </nav>

    <!-- Page Header -->
    <div class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        {categoryData.icon && (
          <span class="text-4xl md:text-6xl">{categoryData.icon}</span>
        )}
        <h1 class="text-4xl md:text-6xl font-black text-white tracking-tight">
          {subcategoryName}
        </h1>
      </div>

      <h2 class="text-xl md:text-2xl font-bold text-slate-300 mb-6 font-mono">
        Drinking Water Testing & Wastewater Analysis Services
      </h2>

      <p class="text-lg text-slate-400 max-w-3xl leading-relaxed mb-8">
        Find verified <strong class="text-white">water quality testing laboratories</strong> and
        compare <strong class="text-white">drinking water analysis services</strong> from
        ISO 17025 accredited laboratories worldwide.
        {subcategoryDescription}
      </p>

      <div class="flex items-center gap-4">
        <div class="px-6 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 font-black text-sm uppercase tracking-widest">
          {totalListings} verified {totalListings === 1 ? 'provider' : 'providers'}
        </div>
        <div class="px-6 py-2 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 font-black text-sm uppercase tracking-widest">
          {sortedRegions.length} {sortedRegions.length === 1 ? 'region' : 'regions'}
        </div>
      </div>
    </div>

    <AdUnit type="horizontal" class="mb-12" />

    <!-- Error Handling -->
    {listingsError && (
      <div class="glass-card bg-red-500/5 border-red-500/20 p-6 mb-8 flex items-center gap-4">
        <span class="text-red-500 text-2xl">⚠️</span>
        <p class="text-red-200/80 font-medium">Error loading directory. Our engineers have been notified.</p>
      </div>
    )}

    <!-- Regions Grid -->
    {sortedRegions.length > 0 ? (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedRegions.map(([region, regionListings]) => {
          const featuredCount = regionListings.filter(l => l.featured).length;
          const verifiedCount = regionListings.filter(l => l.verified).length;

          return (
            <a
              href={`/environmental-testing/${region.toLowerCase()}?filter=water-quality`}
              class="glass-card glass-card-hover p-8 group flex flex-col justify-between"
            >
              <div>
                <div class="flex justify-between items-start mb-6">
                  <h3 class="text-2xl font-black text-white group-hover:text-emerald-400 transition-colors tracking-tight">
                    {region.toUpperCase()}
                  </h3>
                  <span class="bg-white/5 text-slate-300 text-xs font-black px-3 py-1 rounded-full border border-white/10 group-hover:bg-emerald-500/10 group-hover:text-emerald-400 transition-colors">
                    {regionListings.length}
                  </span>
                </div>

                <div class="space-y-3">
                  <div class="flex items-center justify-between text-sm">
                    <span class="text-slate-500 font-bold uppercase tracking-widest text-[10px]">Providers</span>
                    <span class="text-slate-300 font-mono">{regionListings.length}</span>
                  </div>
                  {featuredCount > 0 && (
                    <div class="flex items-center justify-between text-sm">
                      <span class="text-slate-500 font-bold uppercase tracking-widest text-[10px]">Featured</span>
                      <span class="text-amber-500 font-mono">{featuredCount}</span>
                    </div>
                  )}
                  {verifiedCount > 0 && (
                    <div class="flex items-center justify-between text-sm">
                      <span class="text-slate-500 font-bold uppercase tracking-widest text-[10px]">Verified</span>
                      <span class="text-emerald-400 font-mono">{verifiedCount}</span>
                    </div>
                  )}
                </div>
              </div>

              <div class="mt-8 pt-6 border-t border-white/5 flex items-center justify-between group-hover:text-emerald-400 transition-colors">
                <span class="text-xs font-black uppercase tracking-widest">Explore Directory</span>
                <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-24 glass-card border-dashed border-white/10">
        <div class="w-16 h-16 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
        <p class="text-slate-400 text-lg font-medium mb-6">No water testing providers listed yet.</p>
        <a href="/contact" class="inline-flex items-center gap-2 px-8 py-3 bg-white/5 hover:bg-white/10 text-white font-bold rounded-full transition-all border border-white/10">
          Be the first to list here
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </a>
      </div>
    )}

    <!-- CTA Section -->
    {totalListings > 0 && (
      <div class="mt-20 glass-card p-10 border-blue-500/20 bg-gradient-to-r from-blue-600/10 to-emerald-500/10 relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-64 h-64 bg-emerald-500/10 blur-[100px] rounded-full -mr-32 -mt-32"></div>
        <div class="flex flex-col md:flex-row items-center justify-between gap-8 relative z-10">
          <div class="text-center md:text-left">
            <h2 class="text-3xl font-black text-white mb-3">List Your Water Lab</h2>
            <p class="text-slate-400 text-lg">Reach high-intent buyers specifically searching for water quality testing and wastewater analysis services.</p>
          </div>
          <a href="/pricing" class="px-10 py-4 bg-white text-black font-black uppercase tracking-widest rounded-full hover:bg-emerald-400 transition-all hover:scale-110 shadow-xl text-center whitespace-nowrap">
            Get Listed Now
          </a>
        </div>
      </div>
    )}
  </main>
</BaseLayout>