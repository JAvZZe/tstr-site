---
// src/pages/[category]/index.astro
import { supabase } from '../../lib/supabase';
import NewsletterBanner from '../../components/NewsletterBanner';
import Footer from '../../components/Footer.astro';
import { MAILTO_LINKS } from '../../lib/contacts';
import { getRedirectUrl } from '../../lib/redirect';

// SSR rendering (output: 'server' in astro.config)

// 1. Params and Data fetching
const { category } = Astro.params;

// Fetch category metadata
const { data: categoryData, error: catError } = await supabase
  .from('categories')
  .select('id, name, slug, description')
  .eq('slug', category)
  .single();

if (catError || !categoryData) {
  return Astro.redirect('/404');
}

// Check for search filters
const url = new URL(Astro.request.url);
const regionFilter = url.searchParams.get('region');
const isFiltered = !!regionFilter;

// Fetch ALL active listings for this category
const { data: allListings, error: listingsError } = await supabase
  .from('listings')
  .select(`
    *,
    location:location_id (
      id,
      name,
      slug
    ),
    listing_categories!inner (
      category_id
    )
  `)
  .eq('status', 'active')
  .eq('listing_categories.category_id', categoryData.id)
  .order('priority_rank', { ascending: false })
  .order('created_at', { ascending: false });

// Group by region OR filter
const filteredListings = isFiltered 
  ? allListings?.filter(l => l.region?.toLowerCase() === regionFilter?.toLowerCase())
  : allListings;

const listingsByRegion = !isFiltered && allListings ? allListings.reduce((acc, listing) => {
  const reg = listing.region || 'GLOBAL';
  if (!acc[reg]) acc[reg] = [];
  acc[reg].push(listing);
  return acc;
}, {} as Record<string, any[]>) : {};

const sortedRegions = Object.entries(listingsByRegion).sort((a, b) => b[1].length - a[1].length);
const totalListings = allListings?.length || 0;

import { formatTitle, formatDescription } from '../../lib/seo';

// Optimized SEO parts
const pageTitle = formatTitle([categoryData.name, 'Regional Directory']);
const pageDescription = formatDescription(
  `Browse ${totalListings} verified ${categoryData.name.toLowerCase()} providers across ${sortedRegions.length} regions. Compare ISO 17025 accredited labs and specialized testing facilities.`
);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <script is:inline set:html={`
      function initApollo(){var n=Math.random().toString(36).substring(7),o=document.createElement("script");
      o.src="https://assets.apollo.io/micro/website-tracker/tracker.iife.js?nocache="+n,o.async=!0,o.defer=!0,
      o.onload=function(){window.trackingFunctions.onLoad({appId:"6979e8021ac917001927e9b2"})},
      document.head.appendChild(o)}initApollo();
    `}></script>
  </head>

  <body class="bg-gray-50 min-h-screen font-sans text-gray-900">

    <!-- Navigation -->
    <NewsletterBanner client:only="react" />
    <nav class="bg-white shadow-sm p-4">
      <div class="max-w-6xl mx-auto flex justify-between items-center">
        <a href="/" class="font-bold text-xl hover:text-blue-600 transition">
          TSTR<span class="text-blue-600">.directory</span>
        </a>
        <div class="flex gap-4">
          <a href="/browse" class="text-gray-600 hover:text-blue-600 font-medium">Browse All</a>
          <a href="/pricing" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-bold hover:bg-blue-700 transition">List Your Lab</a>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-6xl mx-auto p-6">

      <!-- Breadcrumbs -->
      <div class="text-sm text-gray-500 mb-4">
        <a href="/" class="hover:underline">Home</a>
        <span class="mx-2">›</span>
        <span class="text-gray-900 font-medium">{categoryData.name}</span>
      </div>

      <!-- Page Header -->
      <div class="mb-12">
        <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4 tracking-tight">
          {categoryData.name}
        </h1>
        {categoryData.description && (
          <p class="text-xl text-gray-600 max-w-3xl leading-relaxed">
            {categoryData.description}
          </p>
        )}
      </div>

      <!-- Error Handling -->
      {listingsError && (
        <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-8 rounded-r-lg">
          <div class="flex items-center">
            <span class="text-red-400 text-xl mr-3">⚠️</span>
            <p class="text-red-800 font-medium">
              We encountered an error loading the directory. Our engineers have been notified.
            </p>
          </div>
        </div>
      )}

      <!-- Filter Active Indicator -->
      {isFiltered && (
        <div class="mb-8 flex items-center gap-3">
          <span class="text-gray-600">Showing results for:</span>
          <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full font-bold text-sm uppercase tracking-wide">
            📍 {regionFilter}
          </span>
          <a href={`/${category}`} class="text-blue-600 text-sm hover:underline ml-2">Clear filter</a>
        </div>
      )}

      <!-- Content Grid: Regions OR Flat Listing List (if filtered) -->
      {totalListings > 0 && (
        <div>
          {isFiltered ? (
            <div class="grid gap-6">
              {filteredListings?.map((listing) => (
                <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 hover:shadow-md transition">
                  <div class="flex justify-between items-start">
                    <div>
                      <h3 class="text-xl font-bold text-blue-900">
                        {listing.business_name}
                      </h3>
                      <div class="text-sm text-gray-500 mt-1 flex flex-wrap gap-3">
                        <span>📍 {listing.location?.name || listing.region?.toUpperCase()}</span>
                        {listing.featured && (
                          <span class="text-yellow-600 font-semibold">⭐ Featured</span>
                        )}
                        {listing.verified && (
                          <span class="text-green-600 font-semibold">✓ Verified</span>
                        )}
                      </div>
                      {listing.description && (
                        <p class="text-gray-700 mt-3 text-sm line-clamp-2">
                          {listing.description}
                        </p>
                      )}
                    </div>
                    {listing.website && (
                      <a
                        href={getRedirectUrl(listing.website, listing.id)}
                        target="_blank"
                        rel="nofollow noopener noreferrer"
                        class="bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700 transition whitespace-nowrap"
                      >
                        Visit Website
                      </a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
              {sortedRegions.map(([region, regionListings]) => {
                const featuredCount = regionListings.filter(l => l.featured).length;
                const verifiedCount = regionListings.filter(l => l.verified).length;

                return (
                  <a
                    href={`/${category}/${region.toLowerCase()}`}
                    class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 hover:shadow-md hover:border-blue-400 transition group"
                  >
                    <div class="flex justify-between items-start mb-2">
                      <h3 class="text-xl font-bold text-gray-900 group-hover:text-blue-600">
                        {region.toUpperCase()}
                      </h3>
                      <span class="bg-blue-100 text-blue-800 text-sm font-semibold px-2.5 py-0.5 rounded">
                        {regionListings.length}
                      </span>
                    </div>

                    <div class="text-sm text-gray-600 space-y-1">
                      <p>{regionListings.length} {regionListings.length === 1 ? 'provider' : 'providers'}</p>
                      {featuredCount > 0 && (
                        <p class="text-yellow-600">⭐ {featuredCount} featured</p>
                      )}
                      {verifiedCount > 0 && (
                        <p class="text-green-600">✓ {verifiedCount} verified</p>
                      )}
                    </div>

                    <div class="mt-4 text-blue-600 text-sm font-medium group-hover:underline">
                      View all →
                    </div>
                  </a>
                );
              })}
            </div>
          )}
        </div>
      )}

      {totalListings === 0 && (
        <div class="text-center py-16 bg-white rounded-lg border-2 border-dashed border-gray-300">
          <p class="text-gray-500 text-lg mb-2">
            No {categoryData.name.toLowerCase()} listed yet.
          </p>
          <a href="/contact" class="text-blue-600 font-bold hover:underline">
            Be the first to list here →
          </a>
        </div>
      )}

      <!-- CTA Section -->
      {totalListings > 0 && (
        <div class="mt-12 bg-blue-50 border border-blue-200 rounded-lg p-6">
          <div class="flex flex-col md:flex-row items-center justify-between gap-6">
            <div class="text-center md:text-left">
              <h2 class="text-2xl font-bold text-blue-900 mb-1">List Your Lab in this Category</h2>
              <p class="text-blue-800">Reach buyers specifically searching for {categoryData.name.toLowerCase()}.</p>
            </div>
            <a 
              href="/pricing" 
              class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition"
            >
              Get Listed
            </a>
          </div>
        </div>
      )}

    </main>

    <!-- Footer -->
    <Footer />
  </body>
</html>
