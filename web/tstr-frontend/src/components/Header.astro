---
import NewsletterBanner from './NewsletterBanner';
const { showHero = true } = Astro.props;
---

<NewsletterBanner client:load />
<header class="glass-panel sticky top-0 z-50 py-4 px-6 md:px-12 transition-all duration-300">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <!-- Logo Section -->
    <div class="logo">
      <a href="/" class="flex items-center no-underline text-white group">
        <img src="/TSTR-Logo-60px.png" alt="TSTR Logo" class="h-12 w-auto mr-4 transition-transform duration-300 group-hover:scale-110"/>
        <div class="flex flex-col">
          <span class="text-xl md:text-2xl font-black tracking-widest leading-none">TSTR</span>
          <span class="text-2xl md:text-3xl font-light tracking-tighter leading-none text-emerald-400">hub</span>
        </div>
      </a>
    </div>

    <!-- Desktop Navigation -->
    <nav id="desktop-nav" class="desktop-nav hidden md:flex gap-4 items-center">
      <!-- Navigation will be populated by JavaScript -->
    </nav>

    <!-- Mobile Hamburger Menu -->
    <button id="hamburger-btn" class="hamburger-btn md:hidden bg-transparent border-none text-white text-2xl cursor-pointer p-2">
      ☰
    </button>
  </div>

  {showHero && (
    <div class="max-w-4xl mx-auto text-center mt-12 mb-8 animate-fade-up">
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4 tracking-tight text-white leading-tight">
        Specialist Testing <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400">Services & Solutions</span>
      </h1>
      <p class="text-lg md:text-xl text-slate-400 font-medium">
        Oil & Gas • Biopharma • Environmental • Materials Testing
      </p>
    </div>
  )}

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="mobile-menu hidden fixed inset-0 bg-[#020203]/95 backdrop-blur-xl z-[60] p-8">
    <div class="flex flex-col h-full">
      <div class="flex justify-between items-center mb-12">
        <span class="text-2xl font-bold tracking-widest">TSTR <span class="text-emerald-400">hub</span></span>
        <button id="close-menu-btn" class="bg-transparent border-none text-white text-4xl cursor-pointer">×</button>
      </div>
      <nav id="mobile-nav" class="flex flex-col gap-6">
        <!-- Mobile navigation will be populated by JavaScript -->
      </nav>
    </div>
  </div>
</header>

<script>
  import { supabaseBrowser } from '../lib/supabase-browser'

  function createNavLink(href, text, isPrimary = false) {
    const link = document.createElement('a')
    link.href = href
    link.textContent = text
    
    if (isPrimary) {
      link.className = "px-6 py-2.5 rounded-full font-bold text-white transition-all duration-300 text-center block md:inline-block bg-gradient-to-r from-blue-600 to-emerald-500 hover:scale-105 hover:shadow-[0_0_20px_rgba(16,185,129,0.3)] shadow-lg"
    } else {
      link.className = "px-4 py-2 rounded-lg font-medium text-slate-300 hover:text-white hover:bg-white/5 transition-all duration-200 text-center block md:inline-block"
    }
    
    return link
  }

  async function updateNavigation() {
    try {
      const { data: { session } } = await supabaseBrowser.auth.getSession()
      const isLoggedIn = !!session?.user

      // Navigation Items
      const navItems = [
        { href: '/browse', text: 'Browse', primary: false },
        { href: '/blog', text: 'Blog', primary: false },
        { href: '/pricing', text: 'Pricing', primary: false },
        { href: '/contact', text: 'Contact', primary: false }
      ]

      // Update desktop nav
      const desktopNav = document.getElementById('desktop-nav')
      if (desktopNav) {
        desktopNav.innerHTML = ''

        // Auth Link
        const authLink = isLoggedIn 
          ? createNavLink('/account', 'My Account', true)
          : createNavLink('/login', 'Login', true)
        
        // Add auth link first on desktop
        desktopNav.appendChild(authLink)

        // Add other nav items
        navItems.forEach(item => {
          desktopNav.appendChild(createNavLink(item.href, item.text, item.primary))
        })
      }

      // Update mobile nav
      const mobileNav = document.getElementById('mobile-nav')
      if (mobileNav) {
        mobileNav.innerHTML = ''

        const authLink = isLoggedIn 
          ? createNavLink('/account', 'My Account', true)
          : createNavLink('/login', 'Login / Register', true)
        
        mobileNav.appendChild(authLink)

        navItems.forEach(item => {
          mobileNav.appendChild(createNavLink(item.href, item.text, item.primary))
        })
      }
    } catch (error) {
      console.error('Error updating navigation:', error)
    }
  }

  // Mobile menu toggle
  function initMobileMenu() {
    const hamburgerBtn = document.getElementById('hamburger-btn')
    const mobileMenu = document.getElementById('mobile-menu')
    const closeBtn = document.getElementById('close-menu-btn')

    if (hamburgerBtn && mobileMenu) {
      hamburgerBtn.addEventListener('click', () => {
        mobileMenu.classList.remove('hidden')
        document.body.style.overflow = 'hidden'
      })

      if (closeBtn) {
        closeBtn.addEventListener('click', () => {
          mobileMenu.classList.add('hidden')
          document.body.style.overflow = ''
        })
      }

      // Close menu when clicking outside
      mobileMenu.addEventListener('click', (e) => {
        if (e.target === mobileMenu) {
          mobileMenu.classList.add('hidden')
          document.body.style.overflow = ''
        }
      })
    }
  }

  // Initialize
  updateNavigation()
  initMobileMenu()

  // Listen for auth changes
  supabaseBrowser.auth.onAuthStateChange((event, session) => {
    updateNavigation()
  })
</script>