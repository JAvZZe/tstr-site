---
interface Props {
  slot?: string;
  format?: 'auto' | 'fluid' | 'rectangle' | 'vertical' | 'horizontal';
  responsive?: boolean;
  className?: string;
  style?: string;
}

const { 
  slot, // Should be a 10-digit numeric ID from AdSense dashboard
  format = "auto",
  responsive = true,
  className = "",
  style = "display:block"
} = Astro.props;

// Fallback for AdSense ID if environment variable is missing in build pipeline
const adsenseId = import.meta.env.PUBLIC_ADSENSE_ID || "ca-pub-7003918988204966";

// Validation: AdSense slots MUST be numeric strings
const isValidSlot = slot && /^\d+$/.test(slot);

---

<div class={`ad-container my-8 overflow-hidden rounded-xl bg-white/5 border border-white/10 p-4 transition-all hover:border-white/20 ${className}`}>
  <div class="text-[10px] uppercase tracking-wider text-white/30 mb-2 text-center">Advertisement</div>
  {isValidSlot ? (
    <>
      <ins class="adsbygoogle"
           style={style}
           data-ad-client={adsenseId}
           data-ad-slot={slot}
           data-ad-format={format}
           data-full-width-responsive={responsive ? "true" : "false"}></ins>
      <script is:inline>
           (adsbygoogle = window.adsbygoogle || []).push({});
      </script>
    </>
  ) : (
    <div class="py-12 border-2 border-dashed border-white/5 rounded-lg text-center">
      <p class="text-xs text-slate-500 font-medium">Ad Unit Placeholder</p>
      <p class="text-[9px] text-slate-600 mt-1 uppercase tracking-widest">Pending Slot ID</p>
    </div>
  )}
</div>


<style>
  .ad-container {
    min-height: 100px;
  }
</style>
