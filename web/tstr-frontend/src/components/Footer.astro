---
/**
 * ⚠️ CENTRALIZED FOOTER COMPONENT ⚠️
 * 
 * This is the SINGLE footer for the entire site.
 */

import { CONTENT } from '../lib/contacts'
---

<footer class="bg-[#0a0a0b] border-t border-white/5 py-12 px-6 mt-auto">
  <div class="max-w-7xl mx-auto flex flex-col items-center text-center">
    <div class="mb-8">
      <span class="text-2xl font-black tracking-widest text-white">TSTR <span class="text-emerald-400 font-light">hub</span></span>
    </div>

    <p class="text-slate-200 font-medium mb-2">
      &copy; {new Date().getFullYear()} TSTR Hub - Specialist Testing Services, Products and Solutions Directory
    </p>
    
    <p class="text-slate-500 text-sm max-w-2xl mb-8 leading-relaxed">
      {CONTENT.footerTagline}
    </p>

    <div class="flex flex-wrap justify-center gap-6">
      {CONTENT.footerLinks.map((link) => (
        <>
          {link.icon === 'linkedin' ? (
            <a 
              href={link.href} 
              class="text-slate-400 hover:text-[#0077b5] transition-colors duration-300" 
              title={link.label}
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          ) : link.icon === 'x' ? (
            <a 
              href={link.href} 
              class="text-slate-400 hover:text-white transition-colors duration-300" 
              title={link.label}
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932 6.064-6.932zm-1.294 19.497h2.039L6.486 3.24H4.298l13.31 17.41z"/>
              </svg>
            </a>
          ) : (
            <a 
              href={link.href} 
              class="text-slate-400 hover:text-emerald-400 font-medium transition-colors duration-300 no-underline"
            >
              {link.label}
            </a>
          )}
        </>
      ))}
    </div>
  </div>
</footer>

